{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Xrune",
  "scopeName": "source.xrune",
  "fileTypes": ["rune"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#definition" },
    { "include": "#keywords" },
    { "include": "#combinators" },
    { "include": "#nodes" },
    { "include": "#port-access" },
    { "include": "#channel-index" },
    { "include": "#named-argument" },
    { "include": "#numbers" },
    { "include": "#algebra" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.xrune",
          "begin": "//",
          "end": "$",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.xrune" }
          },
          "patterns": [{ "include": "#todo" }]
        },
        {
          "name": "comment.block.xrune",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.begin.xrune" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.comment.end.xrune" }
          },
          "patterns": [{ "include": "#todo" }]
        }
      ]
    },
    "todo": {
      "name": "keyword.codetag.notation.xrune",
      "match": "\\b(TODO|FIXME|XXX|NOTE|HACK)\\b"
    },
    "strings": {
      "name": "string.quoted.double.xrune",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.xrune", "match": "\\\\." }
      ]
    },

    "definition": {
      "comment": "rune foo(...) / sigil bar(...) — highlight the name being defined",
      "match": "\\b(rune|sigil)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.xrune" },
        "2": { "name": "entity.name.function.xrune" }
      }
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.xrune",
          "match": "\\b(rune|sigil|end|input|out|as)\\b"
        },
        {
          "name": "constant.language.boolean.xrune",
          "match": "\\b(true|false)\\b"
        }
      ]
    },

    "combinators": {
      "comment": "over(n, E) and finer(n, E) are builtin combinators, not keywords",
      "name": "support.function.combinator.xrune",
      "match": "\\b(over|finer)\\b(?=\\s*\\()"
    },

    "nodes": {
      "comment": "The standard node vocabulary (xrune::standard_registry)",
      "name": "support.class.node.xrune",
      "match": "\\b(sine|noise|constant|gain|fader|pan|inv|sinv|mix|smix|add|mul|adapt|m2s|s2m|bus|up2|down2|downbloc|stft|stft_fwd|stft_bwd|sah|counter)\\b"
    },

    "port-access": {
      "comment": "amp.gain — the port being addressed",
      "match": "(\\.)([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "punctuation.accessor.xrune" },
        "2": { "name": "variable.other.property.xrune" }
      }
    },

    "channel-index": {
      "comment": "a[0] -> b[1]",
      "match": "(\\[)(\\d+)(\\])",
      "captures": {
        "1": { "name": "punctuation.definition.index.begin.xrune" },
        "2": { "name": "constant.numeric.index.xrune" },
        "3": { "name": "punctuation.definition.index.end.xrune" }
      }
    },

    "named-argument": {
      "comment": "sine(freq = 440) — the argument name, not a binding",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?==)(?!=)",
      "captures": {
        "1": { "name": "variable.parameter.xrune" }
      }
    },

    "numbers": {
      "patterns": [
        { "name": "constant.numeric.hex.xrune", "match": "\\b0[xX][0-9a-fA-F]+\\b" },
        { "name": "constant.numeric.float.xrune", "match": "\\b\\d+\\.\\d+([eE][-+]?\\d+)?\\b" },
        { "name": "constant.numeric.float.xrune", "match": "\\b\\d+[eE][-+]?\\d+\\b" },
        { "name": "constant.numeric.integer.xrune", "match": "\\b\\d+\\b" }
      ]
    },

    "algebra": {
      "comment": "The connection algebra. Longest match first: <: :> ~> -> before : and ,",
      "patterns": [
        { "name": "keyword.operator.merge.xrune", "match": ":>" },
        { "name": "keyword.operator.split.xrune", "match": "<:" },
        { "name": "keyword.operator.modulate.xrune", "match": "~>" },
        { "name": "keyword.operator.wire.xrune", "match": "->" },
        { "name": "keyword.operator.sequential.xrune", "match": ":" },
        { "name": "keyword.operator.parallel.xrune", "match": "," }
      ]
    },

    "operators": {
      "patterns": [
        { "name": "keyword.operator.assignment.xrune", "match": "=" },
        { "name": "keyword.operator.arithmetic.xrune", "match": "[+\\-*/%]" }
      ]
    },

    "identifiers": {
      "name": "variable.other.xrune",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  }
}
